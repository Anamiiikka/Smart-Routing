# ---- Database (Neon Postgres) ----
# Pooled connection (PgBouncer) — used by the Next.js app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true"
# Direct (unpooled) connection — used by Prisma Migrate and the pg-boss worker.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# ---- Auth.js ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# ---- LLM routing ----
# Active provider. If its API key is missing, routing falls back to the mock.
LLM_PROVIDER="mock"            # "openai" | "gemini" | "grok" | "mock"
ROUTING_CONFIDENCE_THRESHOLD="0.7"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Gemini (Google AI Studio) — OpenAI-compatible endpoint
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# Grok (xAI)
XAI_API_KEY=""
XAI_MODEL="grok-2-latest"

# ---- App ----
NODE_ENV="development"
LOG_LEVEL="info"
